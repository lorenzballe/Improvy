<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ shows the launcher icon on the system splash. Force the
         splash background to the app's dark colour instead of white. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/improvy_splash</item>
    </style>
</resources>
